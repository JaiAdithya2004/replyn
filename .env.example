# Copy this file to ".env" and fill in at least one key. .env is git-ignored.
#
# Providers are tried in order (PROVIDER_ORDER, default "groq,openrouter,gemini");
# if one is rate-limited, the next is used automatically.
#
#   Groq       : https://console.groq.com/keys      (starts gsk_ , fast + reliable free tier)
#   OpenRouter : https://openrouter.ai/keys          (starts sk-or-)
#   Gemini     : https://aistudio.google.com/apikey  (starts AIza , NOT AQ.Ab8)

GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
GEMINI_API_KEY=AIza...

# Optional overrides
PROVIDER_ORDER=groq,openrouter,gemini
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GEMINI_MODEL=gemini-2.0-flash
