{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "replyn-extension.zip", "use": "@vercel/static" },
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "{eval/llm.py,eval/dataset.json,backend/rag.py}" }
    }
  ],
  "routes": [
    { "src": "/health", "dest": "/api/health.py" },
    { "src": "/suggest", "dest": "/api/suggest.py" },
    { "src": "/replyn-extension.zip", "dest": "/replyn-extension.zip" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
